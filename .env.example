# Booqable — Toolio v4 API root (https only, no trailing slash). Same as Booqable docs:
#   https://toolio-inc.booqable.com/api/4/
# Legacy host-only https://toolio-inc.booqable.com is still accepted and normalized to /api/4.
# This is where the *app calls* Booqable (REST). Your *webhook receiver* is on Vercel:
#   https://<project>.vercel.app/api/booqable-order-created — NOT on toolio-inc.booqable.com.
BOOQABLE_BASE_URL=https://toolio-inc.booqable.com/api/4
BOOQABLE_API_KEY=

# Stripe API key (sk_test_... or sk_live_...) — used to create Identity verification sessions
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_...) — used to verify identity.verification_session.verified events
STRIPE_WEBHOOK_SECRET=

# Optional: Stripe Identity verification flow ID (vf_...) from Dashboard. When set, sessions use this flow instead of type: document.
STRIPE_IDENTITY_FLOW_ID=vf_1T2eus14EDv5udF1kqGZTowh

# Resend — for sending verification emails (Vercel + local). Set on Vercel for webhook flow.
RESEND_API_KEY=
# Sender address (must be a verified domain in Resend). For testing use: Toolio Rentals <onboarding@resend.dev>
RESEND_FROM=

# Optional: for scripts/trigger-booqable-webhook.mjs (simulated webhook to Vercel)
# BOOQABLE_CUSTOMER_ID=   # Real Booqable customer UUID (e.g. Zachary Quinn)
# CUSTOMER_EMAIL=zackquinn6@gmail.com
# WEBHOOK_URL=https://stripeidentity.vercel.app/api/booqable-order-created
#
# Booqable → identity: use Booqable’s built-in automation (Make / Zapier / etc.); add an
# HTTP POST step to https://<project>.vercel.app/api/booqable-order-created with body
# { "order": { "id": "<order uuid>", "customer_id": "<customer uuid>" } }.
# Zapier: see docs/zapier-booqable-identity.md
#
# Booqable native webhooks → Vercel: any order.* POST; handler GETs order and runs identity only if status=reserved.
# Same handler URLs: /api/booqable-order-created, /api/webhook, /api/webhooks/booqable, /webhook/booqable
# BOOQABLE_WEBHOOK_TARGET_URL=https://<project>.vercel.app/api/booqable-order-created
# Then: node scripts/register-booqable-webhook-endpoint.mjs
# List what Booqable has registered: node scripts/list-booqable-webhook-endpoints.mjs
